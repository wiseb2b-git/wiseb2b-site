<div class="cookie-info" id="cookieBar">
  <div class="cookie-info-inner">
    <div class="cookie-info-header">
      <div class="cookie-info-header-title">Pliki cookie</div>
      <div class="cookie-info-header-close"><a href="#" id="cookieClose">zamknij <span class="cookie-x">[x]</span></a></div>
    </div>
    <div class="cookie-info-content">
      Strona korzysta z plików cookies. Są one wykorzystywane w celu jak najlepszego świadczenia usług i dostosowania strony do Państwa potrzeb.
    </div>
  </div>
</div>

<script>
  const bar = document.getElementById('cookieBar');
  const closeBtn = document.getElementById('cookieClose');

  if (localStorage.getItem('cookiesAccepted')) {
    bar?.remove();
  } else {
    if (bar) bar.style.display = 'block';
  }

  closeBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    localStorage.setItem('cookiesAccepted', 'true');
    bar?.remove();
  });
</script>

<!-- Styles handled by theme-inline.css (body .cookie-info) -->
