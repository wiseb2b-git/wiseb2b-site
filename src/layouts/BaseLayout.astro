---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBar from '../components/CookieBar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  webPageType?: string;
  article?: {
    headline: string;
    image: string;
    datePublished: string;
    dateModified?: string;
    authorName?: string;
    authorJob?: string;
    description?: string;
  };
  faq?: Array<{ question: string; answer: string }>;
  review?: {
    text: string;
    author: string;
    role: string;
  };
  service?: {
    name: string;
    serviceType: string;
    description: string;
  };
}

const {
  title,
  description = 'Platforma B2B dla firm handlowych i produkcyjnych. Zwiększ sprzedaż i obniż koszty obsługi procesu sprzedaży z WiseB2B.',
  ogImage = '/images/wiseb2b-og.png',
  noindex = false,
  webPageType,
  article,
  faq,
  review,
  service,
} = Astro.props;

const siteUrl = 'https://wiseb2b.eu';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = title === 'Strona główna' ? 'WiseB2B – eCommerce B2B Platform' : `${title} | WiseB2B`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;

const breadcrumbLabels: Record<string, string> = {
  'platforma-b2b': 'Platforma B2B',
  'pakiety-obszary-moduly': 'Pakiety, obszary i moduły',
  'dla-kogo': 'Dla kogo',
  'dla-dystrybutorow': 'Dla dystrybutorów',
  'dla-producentow': 'Dla producentów',
  'baza-wiedzy': 'Baza wiedzy',
  'bezpieczna-migracja': 'Bezpieczna migracja',
  'proces-wdrozenia': 'Proces wdrożenia',
  'agent-ai': 'Agent AI',
  'panel-handlowca': 'Panel Handlowca',
  'case-study': 'Case study',
  'wsparcie': 'Wsparcie',
  'wdrozenia': 'Wdrożenia',
  'o-nas': 'O nas',
  'prezentacja-produktowa': 'Prezentacja produktowa',
  'fundusze-europejskie': 'Fundusze europejskie',
  'partnerzy': 'Partnerzy',
  'funkcje': 'Funkcje',
  'integracje': 'Integracje',
};
const breadcrumbItems = [];
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
let currentPath = '';
breadcrumbItems.push({ name: 'Strona główna', url: siteUrl + '/' });
for (const part of pathParts) {
  currentPath += '/' + part;
  const name = breadcrumbLabels[part] || part.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  breadcrumbItems.push({ name, url: siteUrl + currentPath + '/' });
}

const isPlatformPage = Astro.url.pathname.startsWith('/platforma-b2b/') || Astro.url.pathname === '/platforma-b2b';
const absoluteImage = (src: string) => src.startsWith('http') ? src : new URL(src, siteUrl).href;

const hasBreadcrumb = breadcrumbItems.length > 1;

const webPageNode: any = {
  "@type": webPageType || "WebPage",
  "@id": canonicalUrl + "#webpage",
  "url": canonicalUrl,
  "name": fullTitle,
  "description": description,
  "isPartOf": { "@id": siteUrl + "/#website" },
  "inLanguage": "pl-PL",
};
if (hasBreadcrumb) {
  webPageNode["breadcrumb"] = { "@id": canonicalUrl + "#breadcrumb" };
}

const graph: any[] = [
  {
    "@type": "Organization",
    "@id": siteUrl + "/#organization",
    "name": "WiseB2B",
    "url": siteUrl + "/",
    "description": "Platforma eCommerce B2B dla firm handlowych i produkcyjnych. Łączy sklep B2B, Panel Handlowca i Agentów AI w jednym środowisku.",
    "logo": {
      "@type": "ImageObject",
      "url": siteUrl + "/svg/logo-wiseb2b_black.svg",
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "telephone": "+48717847933",
      "url": siteUrl + "/prezentacja-produktowa/",
      "availableLanguage": "Polish",
    },
    "sameAs": [
      "https://www.linkedin.com/company/wiseb2b/",
      "https://www.facebook.com/wiseb2b",
    ],
  },
  {
    "@type": "WebSite",
    "@id": siteUrl + "/#website",
    "url": siteUrl + "/",
    "name": "WiseB2B",
    "description": "Platforma B2B dla firm handlowych i produkcyjnych",
    "inLanguage": "pl-PL",
    "publisher": { "@id": siteUrl + "/#organization" },
  },
  webPageNode,
];

if (hasBreadcrumb) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": canonicalUrl + "#breadcrumb",
    "itemListElement": breadcrumbItems.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": item.url,
    })),
  });
}

if (isPlatformPage) {
  graph.push({
    "@type": "SoftwareApplication",
    "@id": siteUrl + "/#software",
    "name": "WiseB2B",
    "url": siteUrl + "/platforma-b2b/",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Platforma eCommerce B2B łącząca sklep B2B, Panel Handlowca i Agenta AI. Przeznaczona dla dystrybutorów, hurtowni i producentów.",
    "inLanguage": "pl-PL",
    "publisher": { "@id": siteUrl + "/#organization" },
    "featureList": [
      "Sklep B2B z katalogiem produktów i grupami klientów",
      "Panel Handlowca (Sales CRM)",
      "Agent AI do obsługi zamówień",
      "Integracja z systemami ERP",
      "Dostęp do kodu źródłowego",
      "Architektura pluginowa bez vendor-lock"
    ],
    "offers": {
      "@type": "AggregateOffer",
      "url": siteUrl + "/platforma-b2b/pakiety-obszary-moduly/",
      "priceCurrency": "PLN",
      "lowPrice": "0",
      "offerCount": "3",
      "availability": "https://schema.org/OnlineOnly",
    },
  });
}

if (faq && faq.length > 0) {
  graph.push({
    "@type": "FAQPage",
    "mainEntity": faq.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer,
      },
    })),
  });
}

if (article) {
  const authorName = article.authorName || "WiseB2B";
  const authorSlug = authorName.toLowerCase().replace(/\s+/g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
  const authorNode: any = {
    "@type": "Person",
    "@id": siteUrl + "/#author-" + authorSlug,
    "name": authorName,
  };
  if (article.authorJob) {
    authorNode["jobTitle"] = article.authorJob;
  }
  graph.push({
    "@type": "BlogPosting",
    "@id": canonicalUrl + "#article",
    "headline": article.headline,
    "description": article.description || description,
    "image": absoluteImage(article.image),
    "datePublished": article.datePublished,
    "dateModified": article.dateModified || article.datePublished,
    "inLanguage": "pl-PL",
    "author": authorNode,
    "publisher": { "@id": siteUrl + "/#organization" },
    "mainEntityOfPage": canonicalUrl,
  });
}

if (review) {
  graph.push({
    "@type": "Review",
    "reviewBody": review.text,
    "author": {
      "@type": "Person",
      "name": review.author,
      "jobTitle": review.role,
    },
    "itemReviewed": { "@id": siteUrl + "/#software" },
  });
}

if (service) {
  graph.push({
    "@type": "Service",
    "@id": canonicalUrl + "#service",
    "name": service.name,
    "serviceType": service.serviceType,
    "description": service.description,
    "provider": { "@id": siteUrl + "/#organization" },
    "areaServed": { "@type": "Country", "name": "Polska" },
    "url": canonicalUrl,
    "inLanguage": "pl-PL",
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {Astro.url.pathname === '/' && <link rel="preload" as="image" href="/images/bg-desktop-main-head.webp" type="image/webp" fetchpriority="high" media="(min-width: 768px)" />}
    {Astro.url.pathname === '/' && <link rel="preload" as="image" href="/images/bg-mobile-main-head.webp" type="image/webp" media="(max-width: 767px)" />}
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="WiseB2B" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      '//www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-T8FXB66');
    </script>

    <!-- Google Analytics GA4 -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("set","linker",{"domains":["wiseb2b.eu"]});
      gtag("js", new Date());
      gtag("set", "developer_id.dZTNiMT", true);
      gtag("config", "GT-P842WK5T");
    </script>

    <!-- Snitcher -->
    <script is:inline>
      !function(e){"use strict";var t=e&&e.namespace;if(t&&e.profileId&&e.cdn){var i=window[t];if(i&&Array.isArray(i)||(i=window[t]=[]),!i.initialized&&!i._loaded)if(i._loaded)console&&console.warn("[Radar] Duplicate initialization attempted");else{i._loaded=!0;["track","page","identify","group","alias","ready","debug","on","off","once","trackClick","trackSubmit","trackLink","trackForm","pageview","screen","reset","register","setAnonymousId","addSourceMiddleware","addIntegrationMiddleware","addDestinationMiddleware","giveCookieConsent"].forEach((function(e){var a;i[e]=(a=e,function(){var e=window[t];if(e.initialized)return e[a].apply(e,arguments);var i=[].slice.call(arguments);return i.unshift(a),e.push(i),e})})),-1===e.apiEndpoint.indexOf("http")&&(e.apiEndpoint="https://"+e.apiEndpoint),i.bootstrap=function(){var t,i=document.createElement("script");i.async=!0,i.type="text/javascript",i.id="__radar__",i.setAttribute("data-settings",JSON.stringify(e)),i.src=[-1!==(t=e.cdn).indexOf("http")?"":"https://",t,"/releases/latest/radar.min.js"].join("");var a=document.scripts[0];a.parentNode.insertBefore(i,a)},i.bootstrap()}}else"undefined"!=typeof console&&console.error("[Radar] Configuration incomplete")}({
        "apiEndpoint": "radar.snitcher.com",
        "cdn": "cdn.snitcher.com",
        "namespace": "Snitcher",
        "profileId": "s456jByNFe"
      });
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/svg/logo-wiseb2b.svg" />
    <link rel="stylesheet" href="/css/bootstrap-grid.min.css" />
    <link rel="stylesheet" href="/css/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/css/slick.min.css" />
    <link rel="stylesheet" href="/css/theme-inline.css" />
    <link rel="stylesheet" href="/css/otree.css" />
    <link rel="stylesheet" href="/css/styles.min.css" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-T8FXB66" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBar />

    <script is:inline>
      // Intersection Observer for .lm-observer elements
      var lmObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.lm-observer').forEach(function(el) {
        lmObserver.observe(el);
      });
    </script>
    <script defer src="/js/wow.min.js"></script>
    <script defer src="/js/swiper-bundle.min.js"></script>
    <script defer src="/js/custom.js"></script>
  </body>
</html>
