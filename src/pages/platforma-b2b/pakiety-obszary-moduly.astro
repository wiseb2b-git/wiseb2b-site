<script>
  // Accordion for price-functions sections
  document.querySelectorAll('.price-functions .element h5').forEach(h5 => {
    h5.addEventListener('click', () => {
      h5.closest('.element').classList.toggle('show');
    });
  });

  // "Rozwiń wszystkie" / "Zwiń wszystkie"
  const actionEl = document.querySelector('.price-functions__action');
  if (actionEl) {
    const hideBtn = actionEl.querySelector('.hide');
    const showBtn = actionEl.querySelector('.show');
    const elements = document.querySelectorAll('.price-functions .element');

    showBtn.addEventListener('click', () => {
      elements.forEach(el => el.classList.add('show'));
      showBtn.style.display = 'none';
      hideBtn.style.display = 'inline';
    });

    hideBtn.addEventListener('click', () => {
      elements.forEach(el => el.classList.remove('show'));
      hideBtn.style.display = 'none';
      showBtn.style.display = 'inline';
    });
  }

  // FAQ accordion for questions section
  document.querySelectorAll('.questions__items .item h2').forEach(h2 => {
    h2.addEventListener('click', () => {
      h2.closest('.item').classList.toggle('show');
    });
  });
</script>

