</header>

<script is:inline>
// Submenu toggle for desktop
document.querySelectorAll('.submenu.menu-no-click > a').forEach(function(link) {
  link.addEventListener('click', function(e) {
    if (window.innerWidth > 991) {
      e.preventDefault();
    }
  });

  link.parentElement.addEventListener('mouseenter', function() {
    if (window.innerWidth > 991) {
      var submenuId = this.getAttribute('data-submenu');
      var box = document.getElementById(submenuId);
      if (box) {
        // Hide all submenu boxes first
        document.querySelectorAll('.submenu-box').forEach(function(b) { b.classList.remove('show'); });
        document.querySelectorAll('.submenu.menu-no-click').forEach(function(li) { li.classList.remove('show'); });
        box.classList.add('show');
        this.classList.add('show');
      }
    }
  });
});

// Hide submenu when mouse leaves both the menu item and submenu box
document.querySelectorAll('.submenu-box').forEach(function(box) {
  box.addEventListener('mouseleave', function() {
    this.classList.remove('show');
    document.querySelectorAll('.submenu.menu-no-click').forEach(function(li) { li.classList.remove('show'); });
  });
});

document.querySelector('.header')?.addEventListener('mouseleave', function() {
  document.querySelectorAll('.submenu-box').forEach(function(b) { b.classList.remove('show'); });
  document.querySelectorAll('.submenu.menu-no-click').forEach(function(li) { li.classList.remove('show'); });
});

// Sticky header
var header = document.getElementById('header');
window.addEventListener('scroll', function() {
  if (window.scrollY > 50) {
    header?.classList.add('header--sticky');
  } else {
    header?.classList.remove('header--sticky');
  }
});

// Mobile menu
var hamburger = document.querySelector('.js-mobile-menu-hamburger');
hamburger?.addEventListener('click', function() {
  this.classList.toggle('active');
  document.querySelector('.header')?.classList.toggle('menu-mobile-open');
  document.body.classList.toggle('no-scroll');
});
</script>
