---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const partners = await getCollection('partnerzy');
  return partners.map((partner) => ({
    params: { slug: partner.id },
    props: { partner },
  }));
}

const { partner } = Astro.props;
const { Content } = await render(partner);
const { name, logo, website, phone, email, linkedin, specialization, shortDescription } = partner.data;

// Extract domain for display
const domain = new URL(website).hostname.replace('www.', '');
---

<BaseLayout title={`${name} – partner wdrożeniowy WiseB2B`} description={shortDescription}>

<div class="mceContentBody partner-detail">
  <div class="container">
    <div class="row">
      <div class="col-xl-8 offset-xl-2 col-lg-10 offset-lg-1">

        <!-- Header: logo + info -->
        <div class="partner-header">
          <div class="partner-header__logo">
            <img src={logo} alt={name} />
          </div>
          <div class="partner-header__info">
            <h1 class="p_semi_1">{name}</h1>
            <div class="partner-header__specs">
              {specialization.map((spec) => (
                <span class="p_regular_3">{spec}</span>
              ))}
            </div>
            <div class="partner-header__links">
              <a href={website} target="_blank" rel="noopener noreferrer" class="p_regular_3">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9b062" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                {domain}
              </a>
              {phone && (
                <a href={`tel:${phone.replace(/\s/g, '')}`} class="p_regular_3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9b062" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {phone}
                </a>
              )}
              {email && (
                <a href={`mailto:${email}`} class="p_regular_3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d9b062" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  {email}
                </a>
              )}
              {linkedin && (
                <a href={linkedin} target="_blank" rel="noopener noreferrer" class="p_regular_3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="#d9b062"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  LinkedIn
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class="partner-content">
          <Content />
        </div>

      </div>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="cta-expert">
  <div class="container">
    <div class="row">
      <div class="col-lg-6 offset-lg-3 lm-observer">
        <h2 class="h2_semi">Zainteresowany wdrożeniem WiseB2B?</h2>
        <p class="p_regular_1">Skontaktuj się z nami lub bezpośrednio z&nbsp;partnerem.</p>
        <div class="cta-expert__buttons">
          <a class="wise-button wise-button--wise-harvest" href="/prezentacja-produktowa/">Zamów rozmowę z ekspertem</a>
        </div>
      </div>
    </div>
  </div>
</div>

</BaseLayout>

<style>
  .partner-header {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    margin-top: 60px;
    padding-bottom: 32px;
    border-bottom: 1px solid #e8e6ea;
  }

  .partner-header__logo {
    flex-shrink: 0;
    width: 160px;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8f8fa;
    border-radius: 8px;
    padding: 16px;
  }

  .partner-header__logo img {
    max-height: 68px;
    max-width: 128px;
    width: auto;
    height: auto;
  }

  .partner-header__info {
    flex: 1;
  }

  .partner-header__info h1 {
    margin: 0 0 8px;
    font-size: 2.4rem;
  }

  .partner-header__specs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .partner-header__specs span {
    display: inline-block;
    color: #d9b062;
    background: rgba(217, 176, 98, 0.08);
    padding: 2px 10px;
    border-radius: 100px;
    font-size: 1.3rem;
  }

  .partner-header__links {
    display: flex;
    gap: 16px;
  }

  .partner-header__links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #5a5565;
    text-decoration: none;
    font-size: 1.4rem;
    transition: color 0.2s;
  }

  .partner-header__links a:hover {
    color: #d9b062;
  }

  .partner-content {
    margin-top: 40px;
  }

  .partner-content :global(h2) {
    font-size: 1.8rem;
    font-weight: 600;
    margin: 32px 0 12px;
    color: #312b3f;
  }

  .partner-content :global(h3) {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 24px 0 8px;
    color: #312b3f;
  }

  .partner-content :global(p) {
    font-size: 1.5rem;
    line-height: 1.7;
    color: #5a5565;
    margin-bottom: 12px;
  }

  .partner-content :global(ul) {
    margin: 12px 0;
    padding-left: 24px;
    list-style: disc;
  }

  .partner-content :global(ul ul) {
    list-style: circle;
  }

  .partner-content :global(ol) {
    margin: 12px 0;
    padding-left: 24px;
    list-style: decimal;
  }

  .partner-content :global(li) {
    font-size: 1.5rem;
    line-height: 1.7;
    color: #5a5565;
    margin-bottom: 6px;
  }

  .partner-content :global(li::marker) {
    color: #d9b062;
  }

  @media (max-width: 768px) {
    .partner-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 20px;
    }

    .partner-header__specs {
      justify-content: center;
    }

    .partner-header__links {
      justify-content: center;
    }
  }
</style>
