---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Agent AI WiseB2B – inteligentna automatyzacja e-Commerce B2B" description="Agent AI WiseB2B to natywny moduł platformy B2B, który automatyzuje procesy, odciąża handlowców i personalizuje doświadczenia zakupowe klientów.">

<!-- Sekcja 1: Hero -->
<div class="agent-ai-hero">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <div class="agent-ai-hero__content lm-observer">
          <h1 class="h1_semi">Nowy poziom efektywności e&#8209;Commerce&nbsp;B2B dzięki Agentom&nbsp;AI</h1>
          <p class="p_regular_1">Przestań traktować sztuczną inteligencję jako ciekawostkę. Wdrażamy narzędzia, które wykonują realną pracę: automatyzują procesy, odciążają handlowców i personalizują doświadczenia zakupowe Twoich klientów.</p>
          <a class="wise-button wise-button--wise-harvest" href="/prezentacja-produktowa/">Zamów demo i sprawdź AI w akcji</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sekcja 2: Film YouTube -->
<div class="agent-ai-video">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <div class="agent-ai-video__wrapper lm-observer">
          <div class="agent-ai-video__embed" id="yt-player-wrapper">
            <img
              src="https://img.youtube.com/vi/-l65_JZ0HVg/maxresdefault.jpg"
              alt="Agent AI WiseB2B – prezentacja wideo"
              class="agent-ai-video__poster"
              id="yt-poster"
              loading="lazy"
            />
            <div class="agent-ai-video__play-btn" id="yt-play-btn">
              <svg width="68" height="68" viewBox="0 0 68 68" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="34" cy="34" r="34" fill="rgba(0,0,0,0.6)"/>
                <polygon points="27,20 27,48 50,34" fill="#fff"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sekcja 3: AI, które rozumie Twój biznes -->
<div class="agent-ai-features">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <h2 class="h2_semi agent-ai-features__heading lm-observer">AI, które rozumie Twój biznes</h2>
        <div class="agent-ai-features__grid">

          <div class="agent-ai-feature-card lm-observer">
            <div class="agent-ai-feature-card__icon">
              <img width="40" height="40" src="/images/np_gears_9428_000000-1.png" alt="Zintegrowany AI" loading="lazy" />
            </div>
            <h3 class="p_semi_2">Zintegrowany, nie doklejony</h3>
            <p class="p_regular_3">Agent AI to natywny moduł WiseB2B, który operuje na rzeczywistych danych: Twoich cennikach, stanach magazynowych i indywidualnych warunkach handlowych.</p>
          </div>

          <div class="agent-ai-feature-card lm-observer">
            <div class="agent-ai-feature-card__icon">
              <img width="40" height="40" src="/images/np_operation_2998632_000000-1.png" alt="Nowy interfejs" loading="lazy" />
            </div>
            <h3 class="p_semi_2">Nowy interfejs pracy dla użytkownika</h3>
            <p class="p_regular_3">Narzędzie nie tylko odpowiada na pytania, ale realizuje faktyczne procesy biznesowe, zdejmując ciężar operacyjny z Twojego zespołu.</p>
          </div>

          <div class="agent-ai-feature-card lm-observer">
            <div class="agent-ai-feature-card__icon">
              <img width="40" height="40" src="/images/np_suitcase_4525556_000000-1.png" alt="Wsparcie BOK" loading="lazy" />
            </div>
            <h3 class="p_semi_2">Wsparcie BOK i Handlowców</h3>
            <p class="p_regular_3">Redukcja liczby zapytań o dostępność i proste ofertowanie pozwala Twoim ludziom skupić się na budowaniu relacji, a nie obsłudze transakcji.</p>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sekcja 4: Scenariusze efektywności (Use Cases) -->
<div class="agent-ai-usecases">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <h2 class="h2_semi agent-ai-usecases__heading lm-observer">Przykładowe scenariusze efekywności</h2>

        <!-- Use Case 1: Wsparcie wyboru i kompletowanie ofert -->
        <div class="agent-ai-usecase lm-observer">
          <div class="agent-ai-usecase__text">
            <h3 class="h3_semi">Kompletacja zamówienia z doradztwem</h3>
            <p class="p_regular_3">Zaawansowane wyszukiwanie kontekstowe i doradztwo techniczne. Klient precyzuje wymagania (np. „tylko akumulatorowe", „zestaw od jednego producenta"), a Agent błyskawicznie generuje zestawienia w czytelnej formie tabelarycznej.</p>
          </div>  
          <div class="agent-ai-usecase__visual">
            <img class="agent-ai-mockup-img" src="/images/agent-ai-mockup-02.png" alt="Agent AI – wyszukiwanie kontekstowe i tabela produktów" loading="lazy" />
          </div>
        </div>

        <!-- Use Case 2: Email-to-Cart -->
        <div class="agent-ai-usecase agent-ai-usecase--reverse lm-observer">
          <div class="agent-ai-usecase__text">
            <h3 class="h3_semi">Email-2-Cart</h3>
            <p class="p_regular_3">Przetwarzanie niestrukturyzowanych zapytań i zamówień przesyłanych drogą mailową. Agent analizuje treść maila, identyfikuje indeksy (nawet przy błędnych nazwach) i automatycznie tworzy gotowy koszyk zakupowy. Eliminacja ręcznego wprowadzania zamówień.</p>
          </div>
          <div class="agent-ai-usecase__visual">
            <img class="agent-ai-mockup-img" src="/images/agent-ai-email-to-cart.png" alt="Email-to-Cart: mail z zamówieniem i automatyczna odpowiedź Agenta AI" loading="lazy" />
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<!-- Sekcja 5: Dlaczego WiseB2B AI Agent? -->
<div class="agent-ai-why">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <h2 class="h2_semi agent-ai-why__heading lm-observer">Dlaczego WiseB2B AI Agent?</h2>
        <div class="agent-ai-why__table lm-observer">

          <div class="agent-ai-why__row">
            <div class="agent-ai-why__cell agent-ai-why__cell--feature">
              <p class="p_semi_2">Bezpieczeństwo danych</p>
            </div>
            <div class="agent-ai-why__cell agent-ai-why__cell--benefit">
              <p class="p_regular_3">Agent korzysta z tych samych metod, co interfejs aplikacji. Ma dostęp tylko do tych danych i operacji, które może wykonać operator, i realizuje te działania symulując działanie użytkownika.</p>
            </div>
          </div>

          <div class="agent-ai-why__row">
            <div class="agent-ai-why__cell agent-ai-why__cell--feature">
              <p class="p_semi_2">Agent wbudowany w UI</p>
            </div>
            <div class="agent-ai-why__cell agent-ai-why__cell--benefit">
              <p class="p_regular_3">To nie jest dodatkowy skrypt osadzany na stronie, lecz mechanizm wbudowany w interfejs sklepu. To daje zupełnie nowe doświadczenie użytkownikowi.</p>
            </div>
          </div>

          <div class="agent-ai-why__row">
            <div class="agent-ai-why__cell agent-ai-why__cell--feature">
              <p class="p_semi_2">Nie tylko wyszukiwanie, ale również działanie</p>
            </div>
            <div class="agent-ai-why__cell agent-ai-why__cell--benefit">
              <p class="p_regular_3">Agent to nie jest tylko wyszukiwarka czy porównywarka produktów. Wszystko to, co klient może zrobić w sklepie, Agent też potrafi. Dodać produkty do koszyka, porównać produkty, wykorzystać listy zakupowe, sfinalizować zamówienie, sprawdzić stan realizacji zamówienia.</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sekcja 6: Potwierdzona skuteczność -->
<div class="agent-ai-proof">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <div class="agent-ai-proof__content lm-observer">
          <h2 class="h2_semi">Potwierdzona skuteczność</h2>
          <p class="p_regular_2">Nasze wdrożenia pokazują, że cyfryzacja kanałów sprzedaży to nie tylko wygoda, ale realne wzrosty. Średnio <strong>80% obrotu</strong> u naszych klientów generowane jest przez platformę B2B, a Agent AI jest kolejnym krokiem w optymalizacji tych wyników poprzez uwalnianie czasu pracy handlowców.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sekcja 7: Zobacz agenta w działaniu -->
<div class="agent-ai-demo">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 col-xl-8 offset-xl-2 p-xl-0">
        <div class="agent-ai-demo__content lm-observer">
          <h2 class="h2_semi agent-ai-demo__heading">Zobacz Agenta AI w działaniu</h2>
          <p class="p_regular_2">Przekonaj się sam, jak Agent AI wspiera codzienną pracę w platformie B2B. Na naszym środowisku demo możesz przetestować jego możliwości bez zobowiązań.</p>
          <div class="agent-ai-demo__image">
            <img class="agent-ai-mockup-img" src="/images/agent-ai-01.png" alt="Agent AI WiseB2B – widok interfejsu" loading="lazy" />
          </div>
          <a class="wise-button wise-button--wise-harvest" href="https://demo.wiseb2b.eu" target="_blank" rel="noopener noreferrer">Przejdź do demo</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- CTA -->
<div class="support-cta">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 offset-lg-1 p-lg-0 col-xl-8 offset-xl-2">
        <div class="support-cta__wrapper lm-observer">
          <div class="support-cta__data">
            <div class="support-cta__content">
              <h2 class="h2_semi">Sprawdź AI Agenta w akcji</h2>
              <p class="h5_regular name">Jakub Czyżkowski</p>
              <p class="p_regular_2 job">Lider projektu</p>
              <a class="wise-button wise-button--wise-harvest" href="/prezentacja-produktowa/">Zamów demo</a>
            </div>
          </div>
          <img loading="lazy" width="472" height="372" src="/images/Ellipse-126.png" class="attachment-cta_image size-cta_image" alt="Ekspert WiseB2B" />
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lightbox -->
<div class="agent-ai-lightbox" id="agent-ai-lightbox">
  <img class="agent-ai-lightbox__img" id="agent-ai-lightbox-img" src="" alt="" />
</div>

<style>
  .agent-ai-lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.85);
    cursor: zoom-out;
    justify-content: center;
    align-items: center;
  }
  .agent-ai-lightbox.is-active {
    display: flex;
  }
  .agent-ai-lightbox__img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 4px 40px rgba(0, 0, 0, 0.5);
  }
  .agent-ai-mockup-img {
    cursor: zoom-in;
  }
  .agent-ai-demo {
    padding: 80px 0;
  }
  .agent-ai-demo__content {
    text-align: center;
  }
  .agent-ai-demo__heading {
    margin-bottom: 16px;
  }
  .agent-ai-demo__content > .p_regular_2 {
    margin-bottom: 32px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .agent-ai-demo__image {
    margin-bottom: 32px;
  }
  .agent-ai-demo__image img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }
</style>

<script is:inline>
// Lightbox for mockup images
(function() {
  var lightbox = document.getElementById('agent-ai-lightbox');
  var lightboxImg = document.getElementById('agent-ai-lightbox-img');

  document.querySelectorAll('.agent-ai-mockup-img').forEach(function(img) {
    img.addEventListener('click', function() {
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightbox.classList.add('is-active');
      document.body.style.overflow = 'hidden';
    });
  });

  lightbox.addEventListener('click', function() {
    lightbox.classList.remove('is-active');
    document.body.style.overflow = '';
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && lightbox.classList.contains('is-active')) {
      lightbox.classList.remove('is-active');
      document.body.style.overflow = '';
    }
  });
})();
</script>

<script is:inline>
// YouTube lazy-load on hover/click
(function() {
  var wrapper = document.getElementById('yt-player-wrapper');
  var poster = document.getElementById('yt-poster');
  var playBtn = document.getElementById('yt-play-btn');
  var loaded = false;

  function loadVideo() {
    if (loaded) return;
    loaded = true;
    var iframe = document.createElement('iframe');
    iframe.setAttribute('src', 'https://www.youtube.com/embed/-l65_JZ0HVg?autoplay=1&rel=0');
    iframe.setAttribute('frameborder', '0');
    iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
    iframe.setAttribute('allowfullscreen', '');
    iframe.style.position = 'absolute';
    iframe.style.top = '0';
    iframe.style.left = '0';
    iframe.style.width = '100%';
    iframe.style.height = '100%';
    if (poster) poster.style.display = 'none';
    if (playBtn) playBtn.style.display = 'none';
    wrapper.appendChild(iframe);
  }

  if (wrapper) {
    wrapper.addEventListener('mouseenter', loadVideo);
    wrapper.addEventListener('click', loadVideo);
  }
})();
</script>

</BaseLayout>
